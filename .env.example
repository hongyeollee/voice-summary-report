# === v1: Claude Code + Google Docs 기반 ===

# Google API 인증 (서비스 계정 JSON 키 경로)
GOOGLE_CREDENTIALS_PATH=./credentials/service_account.json

# Google Docs 공유 권한 기본값
# private: 생성자만 접근
# anyone_reader: 링크 있으면 누구나 읽기
# anyone_writer: 링크 있으면 누구나 편집
# anyone_commenter: 링크 있으면 누구나 댓글
GOOGLE_DOCS_SHARE_MODE=anyone_reader

# === v2: 독립 봇 서버 (추후 개발 시) ===
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# LLM_PROVIDER=ollama
